# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d

# Gemini AI (for analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# TextGears (optional, for enhanced readability analysis)
TEXTGEARS_API_KEY=your_textgears_api_key_here

# OpenAI (optional, for future features)
OPENAI_API_KEY=your_openai_api_key_here

# LanguageTool (self-hosted or public)
LANGUAGETOOL_URL=https://api.languagetool.org/v2

# Deepgram (for TTS teleprompter - REQUIRED for TTS to work)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_PROJECT_ID=your_deepgram_project_id_here

# ElevenLabs (alternative TTS, not currently used)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Google TTS (alternative, not currently used)
GOOGLE_TTS_KEY=your_google_tts_key_here

# File Upload
MAX_FILE_SIZE_MB=25
UPLOAD_DIR=uploads

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000
